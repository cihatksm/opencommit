{
    "name": "opencommit",
    "displayName": "OpenCommit — AI Commit Message Generator",
    "description": "Generate conventional commit messages from git diffs using AI (OpenCode Zen, OpenAI, OpenRouter & more) — directly in VS Code's Source Control panel. By cihatksm.",
    "version": "1.1.4",
    "publisher": "cihatksm",
    "author": {
        "name": "Cihat Kösem",
        "email": "cihatksm@cihatksm.com",
        "url": "https://cihatksm.com"
    },
    "license": "MIT",
    "icon": "icon.png",
    "homepage": "https://github.com/cihatksm/opencommit#readme",
    "bugs": {
        "url": "https://github.com/cihatksm/opencommit/issues"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/cihatksm/opencommit"
    },
    "engines": {
        "vscode": "^1.85.0"
    },
    "categories": [
        "SCM Providers",
        "Other"
    ],
    "keywords": [
        "commit",
        "git",
        "conventional commits",
        "ai",
        "opencode"
    ],
    "activationEvents": [
        "onStartupFinished"
    ],
    "main": "./out/extension.js",
    "contributes": {
        "commands": [
            {
                "command": "opencommit.generateCommitMessage",
                "title": "✨ Generate Commit",
                "category": "OpenCommit"
            },
            {
                "command": "opencommit.regenerateCommitMessage",
                "title": "✨ Regenerate",
                "category": "OpenCommit"
            },
            {
                "command": "opencommit.setApiToken",
                "title": "🔑 Set API Token",
                "category": "OpenCommit"
            }
        ],
        "menus": {
            "scm/inputBox": [
                {
                    "command": "opencommit.generateCommitMessage",
                    "when": "scmProvider == git",
                    "group": "navigation",
                    "icon": "$(sparkle)"
                }
            ],
            "commandPalette": [
                {
                    "command": "opencommit.generateCommitMessage",
                    "when": "scmProvider == git"
                },
                {
                    "command": "opencommit.regenerateCommitMessage",
                    "when": "scmProvider == git"
                }
            ]
        },
        "configuration": {
            "title": "OpenCommit",
            "properties": {
                "commitMessageGenerator.apiBaseUrl": {
                    "type": "string",
                    "default": "https://opencode.ai/zen/v1/chat/completions",
                    "description": "The OpenAI-compatible API endpoint URL.\nOpenCode Zen tiers:\n- Free: https://opencode.ai/zen/v1/chat/completions\n- Go: https://opencode.ai/zen/go/v1/chat/completions\n- Go (Messages API): https://opencode.ai/zen/go/v1/messages\n\nOther providers:\n- OpenAI: https://api.openai.com/v1/chat/completions\n- OpenRouter: https://openrouter.ai/api/v1/chat/completions\n- Groq: https://api.groq.com/openai/v1/chat/completions\n- DeepSeek: https://api.deepseek.com/v1/chat/completions\n- Ollama (local): http://localhost:11434/v1/chat/completions\n- Or type \"opencode-cli\" to use the local OpenCode CLI tool."
                },
                "commitMessageGenerator.model": {
                    "type": "string",
                    "default": "deepseek-v4-flash-free",
                    "description": "The AI model to use. Works with any model your API provider supports.",
                    "enum": [
                        "deepseek-v4-flash-free",
                        "deepseek-v4-pro",
                        "deepseek-v4-flash",
                        "kimi-k2.6",
                        "kimi-k2.5",
                        "glm-5.1",
                        "glm-5",
                        "mimo-v2.5",
                        "mimo-v2.5-pro",
                        "mimo-v2.5-free",
                        "minimax-m3",
                        "minimax-m2.7",
                        "minimax-m2.5",
                        "minimax-m3-free",
                        "qwen3.7-max",
                        "qwen3.7-plus",
                        "qwen3.6-plus",
                        "qwen3.6-plus-free",
                        "nemotron-3-super-free",
                        "opencode-gen/kimi-k2.6",
                        "gpt-4o-mini",
                        "gpt-4o",
                        "claude-3-5-sonnet",
                        "custom (type in settings.json)"
                    ]
                },
                "commitMessageGenerator.promptModel": {
                    "type": "boolean",
                    "default": true,
                    "description": "Show a model picker every time before generating a commit message. Disable to always use the default model silently."
                },
                "commitMessageGenerator.conventionalCommit": {
                    "type": "boolean",
                    "default": true,
                    "description": "Generate messages in Conventional Commit format (e.g., feat:, fix:, refactor:)."
                },
                "commitMessageGenerator.multiLine": {
                    "type": "boolean",
                    "default": false,
                    "description": "Generate multi-line commit messages with a body explaining the changes."
                },
                "commitMessageGenerator.maxDiffLength": {
                    "type": "number",
                    "default": 4000,
                    "description": "Maximum diff length (characters) to send to the API. Larger diffs are truncated intelligently."
                }
            }
        }
    },
    "scripts": {
        "vscode:prepublish": "npm run compile",
        "compile": "tsc -p ./",
        "watch": "tsc -watch -p ./",
        "lint": "eslint src --ext ts",
        "package": "vsce package",
        "build-install": "powershell -ExecutionPolicy Bypass -File ./scripts/build-install.ps1",
        "build-install:minor": "powershell -ExecutionPolicy Bypass -File ./scripts/build-install.ps1 minor",
        "build-install:major": "powershell -ExecutionPolicy Bypass -File ./scripts/build-install.ps1 major"
    },
    "devDependencies": {
        "@types/node": "^20.11.0",
        "@types/vscode": "^1.85.0",
        "typescript": "^5.3.3"
    },
    "dependencies": {
        "simple-git": "^3.36.0"
    }
}